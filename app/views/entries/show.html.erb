<% content_for :head do %>
  <% unless @entry.overview.present? || @entry.steps.present? || @entry.code_example.present? %>
    <meta http-equiv="refresh" content="5">
  <% end %>
<% end %>

<div class=" app-container guide-page">
  <div class="guide-header">
    <%= link_to "Back to Home", entries_path, class: "back-link" %>

    <h1><%= @entry.technology %></h1>
    <p><%= @entry.use_case %></p>

    <% if @entry.overview.present? || @entry.steps.present? || @entry.code_example.present? %>

      <% if @entry.overview.present? %>
        <h2>Overview</h2>
        <p><%= @entry.overview %></p>
      <% end %>

      <% if @entry.steps.present? %>
        <h2>Steps</h2>
        <p><%= simple_format(@entry.steps) %></p>
      <% end %>

      <% if @entry.code_example.present? %>
        <h2>Code Example</h2>
        <pre><code><%= @entry.code_example %></code></pre>
      <% end %>

      <% if @safe_doc_link.present? %>
        <h2>Documentation</h2>
        <p>
          <%= link_to "View documentation", @safe_doc_link, target: "_blank", rel: "noopener" %>
        </p>
      <% end %>

    <% else %>

      <div class="generating-message">
        <p><strong>Generating your learning guide... ⏳</strong></p>
        <p>Please wait a few seconds for the page to refresh.</p>
      </div>

    <% end %>

  </div>
</div>