<h1>TeachME! - Technical Learning Assistant</h1>

<div>
  <%= link_to "New Entry", new_entry_path %>
</div>

<br>

<div>
  <% @entries.each do |entry| %>
    <div>
    <strong>
        <%= link_to "#{entry.technology} for #{entry.use_case}", entry_path(entry) %>
    </strong>

      <br>

      <%= entry.overview %>

      <br>

      <%= button_to "Delete", entry, method: :delete, data: { confirm: "Are you sure you want to delete this entry?" } %>
    </div>

    <br>
  <% end %>
</div>